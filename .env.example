PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dekorama
DB_SSL=false
# Set true on Render until migrations exist
DB_SYNCHRONIZE=true
ADMIN_EMAIL=admin@dekorama.com
ADMIN_PASSWORD=change-me-min-8-chars
ADMIN_NAME=Admin Dekorama
JWT_SECRET=change-me-jwt-secret
SESSION_SECRET=change-me-session-secret
INVITATION_TOKEN_SECRET=change-me-invitation-secret
SESSION_TTL_MS=604800000
AUTH_RATE_LIMIT_MAX=20
BREVO_API_KEY=
# Optional demo seed (local only)
SEED_DEMO_USERS=false
SEED_CLIENT_PASSWORD=
SEED_COMMUNITY_PASSWORD=
SEED_MEMBER_PASSWORD=

# Google Cloud Storage
GCS_PROJECT_ID=dekorama-hub
GCS_PRODUCTS_BUCKET=dekorama-hub-products
GCS_INVOICES_BUCKET=dekorama-hub-invoices
# Local: path to service-account JSON. Prod: prefer GCS_CREDENTIALS_JSON
GCS_KEY_FILE=
# GCS_CREDENTIALS_JSON={"type":"service_account",...}
